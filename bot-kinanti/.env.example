# ================================
# Bot Kinanti - Environment Variables
# ================================
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# === Database (Supabase/PostgreSQL) ===
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"
SUPABASE_URL="https://[PROJECT-ID].supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# === Bot Security ===
# Secret key untuk autentikasi broadcast API dari web
BOT_SECRET="your-random-secret-key-here"

# === Server Config ===
# Port untuk bot server (default: 4000)
PORT=4000

# === Optional: JWT untuk Auth ===
JWT_SECRET="your-jwt-secret-key"

# === Optional: Environment ===
NODE_ENV=production

# === AI token pool (Gemini) ===
# Fallback dipakai HANYA bila tabel AiToken kosong. Pool DB (dashboard /admin di web)
# lebih diprioritaskan dan dibagi antara web & bot lewat DB yang sama.
GEMINI_API_KEY=
# Berapa menit sebuah key di-cooldown setelah kena limit 429.
AI_KEY_COOLDOWN_MINUTES=15
