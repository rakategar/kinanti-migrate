# =====================================================================
# Kinanti — konfigurasi Docker (disalin ke .env oleh setup.sh)
# Nilai <GENERATE> akan diisi otomatis oleh setup.sh (openssl / gen-jwt).
# =====================================================================

# --- Domain & TLS (Caddy) ---
# Domain sekolah yang diarahkan ke IP VPS (A record). Untuk uji lokal: localhost
DOMAIN=kinanti.sekolah.sch.id
ACME_EMAIL=admin@sekolah.sch.id

# URL publik yang dipakai app & browser (harus sama dengan yang diakses siswa/guru).
# Produksi: https://$DOMAIN . Uji lokal tanpa TLS bisa: http://localhost
SUPABASE_URL=https://kinanti.sekolah.sch.id
NEXTAUTH_URL=https://kinanti.sekolah.sch.id

# --- Postgres (lokal, di dalam compose) ---
POSTGRES_DB=postgres
POSTGRES_PASSWORD=<GENERATE>

# --- Supabase minimal (Storage) ---
JWT_SECRET=<GENERATE>          # minimal 32 karakter
JWT_EXPIRY=3600
ANON_KEY=<GENERATE>            # JWT HS256 (role anon)
SERVICE_ROLE_KEY=<GENERATE>    # JWT HS256 (role service_role) → dipakai app sbg SUPABASE_KEY
STORAGE_TENANT_ID=kinanti
REGION=local
GLOBAL_S3_BUCKET=stub

# --- Aplikasi web (Next.js) ---
NEXTAUTH_SECRET=<GENERATE>
APP_MODE=production
# Webhook n8n opsional; kosong = penilaian pakai jalur native Gemini.
WEBHOOK_TUGAS_URL=

# --- Dashboard admin token AI (/admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kekuatanai
AI_KEY_COOLDOWN_MINUTES=15

# --- Token AI (Gemini) ---
# Opsional: fallback jika tabel AiToken kosong. Utamakan tambah token via /admin.
GEMINI_API_KEY=

# --- Bot WhatsApp ---
# Secret bearer untuk endpoint /broadcast (web → bot).
BOT_SECRET=<GENERATE>
